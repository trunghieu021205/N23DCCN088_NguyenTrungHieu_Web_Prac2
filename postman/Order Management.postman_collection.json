      "name": "Add Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Tạo đơn hàng mới thành công\", () => {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "\r",
              "let res = pm.response.json();\r",
              "console.log(\"Response:\", res);\r",
              "\r",
              "// FIX: lấy từ data\r",
              "if (res.data && res.data._id) {\r",
              "    pm.environment.set(\"order_id\", res.data._id);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
